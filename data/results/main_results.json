  "conjecture_original": "R_k(x + by = bz) = b^k for all b >= 3, k >= 1 (DISPROVED for b=3 k=5)",
  "conjecture_refined": "R_k(x + by = bz) = b^k iff k <= 2(b-1)",
  "lower_bound_proof": "v_b coloring (b-adic valuation), proved for all b >= 2, k >= 1",
  "upper_bound_proof": "k=1 trivial, k=2 Landman-Robertson 2014, k=3-4 Key Lemma + SAT, k>=5 OPEN",

  "key_lemma": {
    "_description": "Every color class contains a pair (j, j+b^{k-1}) in any valid k-coloring of {1,...,b^k-1}",
    "_implication": "If Key Lemma holds => R_k(x+by=bz) = b^k (see proof_notes.md)",
    "verified": [
      {"b": 3, "k": 2, "holds": true, "time_s": "<0.01"},
      {"b": 3, "k": 3, "holds": true, "time_s": "<1"},
      {"b": 3, "k": 4, "holds": true, "time_s": "~2 per color"},
      {"b": 3, "k": 5, "holds": false, "note": "FAILS — counterexample at n=243"},
      {"b": 4, "k": 2, "holds": true, "time_s": "<0.01"},
      {"b": 4, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 4, "k": 4, "holds": true, "time_s": "~35 per color, all 4 colors verified"},
      {"b": 5, "k": 2, "holds": true, "time_s": "<0.01"},
      {"b": 5, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 5, "k": 4, "holds": true, "time_s": "639 (color 0 verified, others expected same)"},
      {"b": 6, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 7, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 8, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 9, "k": 3, "holds": true, "time_s": "<0.01"},
      {"b": 10, "k": 3, "holds": true, "time_s": "<0.01"}
    ]
  },

